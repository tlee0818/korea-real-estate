# Korean Real Estate API Keys
# Get keys from: https://www.data.go.kr (공공데이터포털)
# 1. Create account at data.go.kr
# 2. Search each API by name
# 3. Click 활용신청 (Apply)
# 4. Copy your 서비스키 from 마이페이지 → 오픈API

# Land Sales History API (국토교통부 토지 매매 실거래가)
# Apply at: https://www.data.go.kr/data/15126466/openapi.do
SALES_HISTORY_API_KEY=your_service_key_here

# Market Price Trends API (한국부동산원 통계)
# Apply at: https://www.data.go.kr/data/15134761/openapi.do
PRICE_TRENDS_API_KEY=your_service_key_here

# Appraised Land Value API (개별공시지가)
# Apply at: https://www.data.go.kr/data/15057159/openapi.do
APPRAISED_VALUE_API_KEY=your_service_key_here

# Zoning & Land Use API (토지이용계획)
# Apply at: https://www.data.go.kr/data/15113034/openapi.do
ZONING_API_KEY=your_service_key_here

# Optional settings
# Default region used when --region is omitted. 42820 = 고성군 (change to your region)
DEFAULT_REGION_CODE=42820
REQUEST_TIMEOUT_SECONDS=30
MAX_RETRIES=3
